{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "description": "Rastro 主窗口能力配置。",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "core:window:default",
    "core:webview:default",
    "dialog:default",
    {
      "identifier": "core:webview:allow-set-webview-position",
      "allow": [{ "url": "asset://**" }]
    }
  ]
}
