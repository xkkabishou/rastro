{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "Rastro",
  "version": "0.1.0",
  "identifier": "com.rastro.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rastro",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/**/*",
            "$DESKTOP/**/*",
            "$DOCUMENT/**/*",
            "$DOWNLOAD/**/*",
            "$TEMP/**/*",
            "$APPDATA/**/*",
            "$APPLOCALDATA/**/*",
            "/Volumes/**/*"
          ]
        }
      },
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; font-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: asset: http://asset.localhost https://asset.localhost http://ipc.localhost http://127.0.0.1:8890 https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {}
}
